<script>
function done() {
    location.href = '/Utilities/BtrfsSnapshots';
}

$(function () {
    var types = ['hourly', 'daily', 'weekly', 'monthly'];
    function checkGlobalWarnings() {
        types.forEach(function (t) {
            var enabled = $('#g_' + t + '_enabled').val() === 'yes';
            var retain  = parseInt($('#g_' + t + '_retain').val(), 10);
            $('#g_warn_' + t).toggle(enabled && (isNaN(retain) || retain === 0));
        });
    }
    checkGlobalWarnings();
    types.forEach(function (t) {
        $('#g_' + t + '_enabled, #g_' + t + '_retain').on('change input', checkGlobalWarnings);
    });
});
</script>
