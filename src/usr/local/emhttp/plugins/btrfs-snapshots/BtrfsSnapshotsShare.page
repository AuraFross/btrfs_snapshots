<script>
$(function () {
    var csrf = <?= json_encode($var['csrf_token'] ?? '') ?>;
    var share = '<?= htmlspecialchars($share, ENT_QUOTES) ?>';
    BtrfsSnapshots.init(csrf);
    BtrfsSnapshots.loadShareSnapshots(share);
    BtrfsSnapshots.stopAutoRefresh();

    var schedules = ['hourly', 'daily', 'weekly', 'monthly'];

    // Hide/show per-type fields based on enabled value
    function updateScheduleFields() {
        schedules.forEach(function (type) {
            var val = $('#sched_' + type + '_enabled').val();
            var isGlobal = (val === 'global');
            $('#sched_' + type + '_fields').toggle(!isGlobal);
            // Warn only when explicitly enabled with retain=0
            var retain = parseInt($('#sched_' + type + '_retain').val(), 10);
            var warn = (val === 'yes') && (isNaN(retain) || retain === 0);
            $('#warn_' + type).toggle(warn);
        });
    }

    updateScheduleFields();

    schedules.forEach(function (type) {
        $('#sched_' + type + '_enabled').on('change', updateScheduleFields);
        $('#sched_' + type + '_retain').on('input', updateScheduleFields);
    });
});
</script>
